{
  "expo": {
    "name": "Малчин",
    "slug": "malchin-app",
    "version": "1.0.0",
    "description": "Малчин - Монголын малчдад зориулсан иж бүрэн аппликейшн. Мал сүргийн бүртгэл, бэлчээрийн менежмент, цаг агаарын мэдээ, зах зээлийн үнийн мэдээлэл зэргийг нэг дороос авах боломжтой.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "malchinapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2d5016"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.malchin.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Малын зураг авах, бүртгэл хөтлөхөд камер ашиглана.",
        "NSLocationWhenInUseUsageDescription": "Бэлчээрийн байршил тодорхойлох, малын байршлыг тэмдэглэхэд ашиглана."
      }
    },
    "android": {
      "package": "com.malchin.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#2d5016"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2d5016",
          "dark": {
            "backgroundColor": "#121212"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2d5016"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
